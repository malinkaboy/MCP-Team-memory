# ===== IMPORTANT: Change default credentials before deploying! =====

# PostgreSQL
POSTGRES_USER=memory
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Application
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/team_memory
MEMORY_TRANSPORT=http
MEMORY_PORT=3846

# Security (uncomment to enable)
# MEMORY_API_TOKEN=your-secret-token-here
# MEMORY_CORS_ORIGIN=https://your-domain.com

# Full-text search language: simple, russian, english, german, etc.
MEMORY_FTS_LANGUAGE=simple

# Embedding provider: ollama, gemini, local, or leave empty to disable
# MEMORY_EMBEDDING_PROVIDER=ollama
# GEMINI_API_KEY=your-gemini-api-key

# Ollama (recommended for self-hosted)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe

# Vector store: qdrant (recommended) or pgvector
# VECTOR_STORE=qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Auto-archive
MEMORY_AUTO_ARCHIVE=true
MEMORY_AUTO_ARCHIVE_DAYS=14

# Logging
LOG_LEVEL=info
