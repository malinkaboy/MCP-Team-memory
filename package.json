{
  "name": "team-memory-mcp",
  "version": "2.0.0",
  "description": "MCP Server for team memory - shared knowledge base for Claude Code agents (PostgreSQL, multi-project)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-static && npm run copy-sql",
    "copy-static": "cpy \"src/web/public/**/*\" dist/web/public/",
    "copy-sql": "cpy \"src/storage/schema.sql\" dist/storage/ --flat",
    "start": "node dist/index.js",
    "start:web": "node dist/index.js",
    "start:stdio": "node -e \"process.env.MEMORY_TRANSPORT='stdio'; import('./dist/index.js')\"",
    "dev": "npm run build && npm run start:web",
    "dev:ui": "npx browser-sync start --proxy \"localhost:3846\" --files \"src/web/public/**/*\" --no-open --port 3847 --no-notify",
    "dev:watch": "npx chokidar-cli \"src/web/public/**/*\" -c \"npm run copy-static\" --initial",
    "docker:build": "npm run build && docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "claude",
    "team-memory",
    "ai-agents",
    "postgresql"
  ],
  "author": "Moorinet Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^4.0.18",
    "cpy-cli": "^6.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
